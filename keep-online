#!/usr/bin/env bash
set -uo pipefail

usage() {
  cat <<'EOF'
usage:
  keep-online [username password]

credentials:
  pass username/password as arguments, or set HFUT_NET_USERNAME and HFUT_NET_PASSWORD
EOF
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing dependency: $1"
    exit 1
  fi
}

campus_curl() {
  curl --noproxy '*' "$@" 2>/dev/null
}

check_internet() {
  local probe code effective

  probe="$(campus_curl -4 -L --connect-timeout 2 -sS -m 4 -o /dev/null -w '%{http_code} %{url_effective}' http://connect.rom.miui.com/generate_204 || true)"
  code="${probe%% *}"
  effective="${probe#* }"
  if [[ "$code" == "204" && "$effective" != *"172.16.200."* && "$effective" != *"192.168.4.1"* && "$effective" != *"210.45.240."* && "$effective" != *"eportal"* ]]; then
    return 0
  fi

  probe="$(campus_curl -4 -L --connect-timeout 2 -sS -m 4 -o /dev/null -w '%{http_code} %{url_effective}' http://connectivitycheck.gstatic.com/generate_204 || true)"
  code="${probe%% *}"
  effective="${probe#* }"
  if [[ "$code" == "204" && "$effective" != *"172.16.200."* && "$effective" != *"192.168.4.1"* && "$effective" != *"210.45.240."* && "$effective" != *"eportal"* ]]; then
    return 0
  fi

  probe="$(campus_curl -4 -L --connect-timeout 2 -sS -m 4 -o /dev/null -w '%{http_code} %{url_effective}' http://www.baidu.com || true)"
  code="${probe%% *}"
  effective="${probe#* }"
  if [[ "$code" =~ ^(200|301|302)$ && "$effective" != *"172.16.200."* && "$effective" != *"192.168.4.1"* && "$effective" != *"210.45.240."* && "$effective" != *"eportal"* ]]; then
    return 0
  fi

  return 1
}

resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  local dir=""
  while [[ -L "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="${dir}/${src}"
  done
  cd -P "$(dirname "$src")" && pwd
}

resolve_credentials() {
  if [[ $# -eq 2 ]]; then
    HFUT_USERNAME="$1"
    HFUT_PASSWORD="$2"
    return 0
  fi

  if [[ $# -eq 0 && -n "${HFUT_NET_USERNAME:-}" && -n "${HFUT_NET_PASSWORD:-}" ]]; then
    HFUT_USERNAME="$HFUT_NET_USERNAME"
    HFUT_PASSWORD="$HFUT_NET_PASSWORD"
    return 0
  fi

  usage
  exit 1
}

main() {
  need_cmd curl

  resolve_credentials "$@"

  if check_internet; then
    echo "keep-online: already online"
    exit 0
  fi

  echo "keep-online: offline detected, trying login"
  "${SCRIPT_DIR}/online" "$HFUT_USERNAME" "$HFUT_PASSWORD"
}

SCRIPT_DIR="$(resolve_script_dir)"
HFUT_USERNAME=""
HFUT_PASSWORD=""
main "$@"
