#!/usr/bin/env bash
set -uo pipefail

GATEWAYS=(
  "http://210.45.240.150/"
)
LEGACY_PORTAL="http://210.45.240.245"
EPORTAL_HOST="http://210.45.240.105:801"

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing dependency: $1"
    exit 1
  fi
}

campus_curl() {
  curl --noproxy '*' "$@" 2>/dev/null
}

join_url() {
  local base="$1"
  local path="$2"
  printf '%s/%s' "${base%/}" "${path#/}"
}

request_status_code() {
  local url="$1"
  campus_curl -sS --connect-timeout 2 -m 5 -o /dev/null -w '%{http_code}' "$url" || true
}

get_local_ip() {
  local ip iface

  if command -v ip >/dev/null 2>&1; then
    ip="$(ip -4 route get 1.1.1.1 2>/dev/null | sed -n -E 's/.* src ([0-9.]+).*/\1/p' | head -n 1 || true)"
  fi

  if [[ -z "$ip" ]] && command -v route >/dev/null 2>&1 && command -v ipconfig >/dev/null 2>&1; then
    iface="$(route -n get default 2>/dev/null | awk '/interface:/ {print $2; exit}' || true)"
    if [[ -n "$iface" ]]; then
      ip="$(ipconfig getifaddr "$iface" 2>/dev/null || true)"
    fi
  fi

  if [[ -z "$ip" ]] && command -v hostname >/dev/null 2>&1; then
    ip="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
  fi

  if [[ -z "$ip" ]] && command -v ifconfig >/dev/null 2>&1; then
    ip="$(ifconfig 2>/dev/null | awk '/inet / && $2 != "127.0.0.1" {print $2; exit}' || true)"
  fi

  if [[ -z "$ip" ]] && command -v ipconfig.exe >/dev/null 2>&1; then
    ip="$(ipconfig.exe 2>/dev/null | tr -d '\r' | awk -F': ' '/IPv4 Address|IPv4 地址/ {print $2; exit}' || true)"
  fi

  printf '%s' "$ip"
}

logout_drcom() {
  local gateway url code

  for gateway in "${GATEWAYS[@]}"; do
    url="$(join_url "$gateway" "F.htm")"
    code="$(request_status_code "$url")"
    if [[ "$code" =~ ^(200|30[12378])$ ]]; then
      return 0
    fi
  done

  url="$(join_url "$LEGACY_PORTAL" "F.htm")"
  code="$(request_status_code "$url")"
  if [[ "$code" =~ ^(200|30[12378])$ ]]; then
    return 0
  fi

  return 1
}

logout_eportal() {
  local ip ts response
  ip="$(get_local_ip)"
  if [[ -z "$ip" ]]; then
    return 1
  fi

  ts="$(date +%s)"

  response="$(campus_curl -sS --connect-timeout 2 -m 6 \
    "${EPORTAL_HOST}/eportal/?c=Portal&a=logout&callback=dr1004&login_method=1&user_account=drcom&user_password=123&ac_logout=1&register_mode=1&wlan_user_ip=${ip}&wlan_user_ipv6=&wlan_vlan_id=1&wlan_user_mac=000000000000&wlan_ac_ip=&wlan_ac_name=&jsVersion=4.1.3&v=${ts}" || true)"
  if [[ -n "$response" ]]; then
    return 0
  fi

  response="$(campus_curl -sS --connect-timeout 2 -m 6 \
    "${EPORTAL_HOST}/eportal/?c=Portal&a=unbind_mac&callback=dr1004&user_account=drcom&wlan_user_ip=${ip}&jsVersion=4.1.3&v=${ts}" || true)"
  [[ -n "$response" ]]
}

main() {
  need_cmd curl
  need_cmd sed

  if logout_drcom; then
    echo "offline: logout request sent (drcom)"
    exit 0
  fi

  if logout_eportal; then
    echo "offline: logout request sent (eportal)"
    exit 0
  fi

  echo "offline: no reachable auth server"
  exit 1
}

main "$@"
