#!/usr/bin/env bash
set -uo pipefail

usage() {
  cat <<'EOF'
usage:
  hfut-net login <username> <password>
  hfut-net logout

aliases:
  hfut-net online <username> <password>
  hfut-net offline
EOF
}

resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  local dir=""
  while [[ -L "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="${dir}/${src}"
  done
  cd -P "$(dirname "$src")" && pwd
}

run_login() {
  if [[ $# -ne 2 ]]; then
    usage
    exit 1
  fi
  "${SCRIPT_DIR}/online" "$1" "$2"
}

run_logout() {
  if [[ $# -ne 0 ]]; then
    usage
    exit 1
  fi
  "${SCRIPT_DIR}/offline"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    login | online)
      run_login "$@"
      ;;
    logout | offline)
      run_logout "$@"
      ;;
    help | -h | --help)
      usage
      ;;
    *)
      echo "unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

SCRIPT_DIR="$(resolve_script_dir)"
main "$@"
